# ----------------------------------------------------------------------------
# Benu — environment variables
# Copy this file to `.env.local` and fill in real values for local development.
# In Vercel, add these in: Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# OpenAI — primary LLM for the menu assistant chatbot.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Unsplash — for fetching real dish photos via the Unsplash API.
# Currently the menu uses source.unsplash.com URLs which don't need a
# key, but the official API does. Use UNSPLASH_ACCESS_KEY for read-only
# requests; UNSPLASH_SECRET_KEY is only needed for OAuth user actions.
# Register an app at: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Optional. Public-facing brand name shown in disclaimers.
NEXT_PUBLIC_BRAND_NAME=Benu
