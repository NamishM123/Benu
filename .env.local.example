# ----------------------------------------------------------------------------
# Benu — environment variables
# Copy this file to `.env.local` and fill in real values for local development.
# In Vercel, add these in: Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# Required for the menu assistant chatbot.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional. Public-facing brand name shown in disclaimers.
NEXT_PUBLIC_BRAND_NAME=Benu
